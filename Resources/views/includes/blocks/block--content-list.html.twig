{% block content_list %}
    {% set block_id = content._id|default %}
    <ul class="block--content-list {{ content.list_typ }} {{ content.attr_class|default }}" data-cms-block-id="{{ block_id }}" {{ sulu_block_preview(content) }}>
        {% if content.blocks|default([]) %}
            {% for block in content.blocks %}
                {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                    content: block,
                    view: view.blocks[loop.index0],
                } %}
            {% endfor %}
        {% endif %}
    </ul>
{% endblock %}
