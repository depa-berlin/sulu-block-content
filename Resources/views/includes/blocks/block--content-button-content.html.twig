{% block content_button_content %}
    {% set block_id = content._id|default %}
    {% if content.link|default %}
        {% set provider_class = (content.icon == true and view.link is defined) ? 'provider-' ~ view.link.provider : '' %}
        <a class="block--content-button-content {{ provider_class }} {{ content.attr_class|default }}"
           href="{{ content.link }}"
           target="{{ view.link.target|default('_self') }}"
           data-cms-block-id="{{ block_id }}"
            {{ include('includes/_partials/aria_attributes.html.twig', {
                aria_blocks: content.aria_blocks|default([])
            }) }}
        {{ sulu_block_preview(content) }}>
            {% if content.blocks|default([]) %}
                {% for block in content.blocks %}
                    {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                        content: block,
                        view: view.blocks[loop.index0],
                    } %}
                {% endfor %}
            {% endif %}
        </a>
    {% endif %}
{% endblock %}
