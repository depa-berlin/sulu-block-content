{% set block_id = content._id|default %}
<div class="block--content-box {{ content.attr_class|default }}"
     {% if content.attr_id|default %}id="{{ content.attr_id }}"{% endif %} data-cms-block-id="{{ block_id }}" {{ sulu_block_preview(content) }}>
    {% if content.blocks|default([]) %}
        {% for block in content.blocks %}
            {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                content: block,
                view: view.blocks[loop.index0],
            } %}
        {% endfor %}
    {% endif %}
</div>
