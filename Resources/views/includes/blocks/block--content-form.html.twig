{% block content_form %}
    {% set block_id = content._id|default %}
    <div class="block--content-form {{ content.attr_class|default('') }}" data-cms-block-id="{{ block_id }}"
    {% for attr in content.dataAttributes|default([]) %}
        {% if attr.type == 'attribute' and attr.name and attr.value %}
            {{ ' data-' ~ attr.name }}="{{ attr.value }}"
        {% endif %}
    {% endfor %}
    {{ sulu_block_preview(content) }}>
    {% if content.form %}
        {% if app.request.get('send') != 'true' %}
            {% set form = sulu_form_build(content.form, 'page', resource.id) %}
            {# FORM THEME #}
            {% if content.floating_status is defined and content.floating_status %}
                {% form_theme form 'form/floating-theme.html.twig' %}
            {% else %}
                {% form_theme form 'form/theme.html.twig' %}
            {% endif %}
            <div class="content-form-form">
                {{ form(form) }}
            </div>
        {% else %}
            <div class="content-form-success">
                {% if content.success_blocks|default([])|length > 0 %}
                    {% for block in content.success_blocks %}
                        {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                            content: block,
                            view: view.success_blocks[loop.index0],
                        } %}
                    {% endfor %}
                {% else %}
                    {{ content.form.data.successText|raw }}
                {% endif %}
            </div>
        {% endif %}
    {% endif %}
    </div>
{% endblock %}
