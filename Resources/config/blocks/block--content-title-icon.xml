<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns:xi="http://www.w3.org/2001/XInclude"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <key>block--content-title-icon</key>
    <meta>
        <title lang="en">Headline with icon</title>
        <title lang="de">Überschrift mit Icon</title>
    </meta>
    <properties>
        <property name="text" type="text_area">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Überschrift</title>
            </meta>
        </property>
        <property name="icon" type="single_media_selection">
            <meta>
                <title lang="en">SVG Icon</title>
                <title lang="de">SVG Icon</title>
            </meta>

            <params>
                <param name="types" value="image"/>

            </params>
        </property>
        <section name="config_1">
            <meta>
                <title lang="en">Config</title>
                <title lang="de">Einstellungen</title>
            </meta>
            <properties>
                <property name="element" type="single_select" colspan="4">
                    <!-- @see https://docs.sulu.io/en/2.2/book/extend-admin.html#selection-field-type -->
                    <meta>
                        <title lang="en">HTML-Element</title>
                        <title lang="de">HTML element</title>
                    </meta>
                    <params>
                        <param name="default_value" value="h2"/>

                        <param name="values" type="collection">
                            <param name="h1">
                                <meta>
                                    <title lang="en">H1</title>
                                    <title lang="de">H1</title>
                                </meta>

                            </param>
                            <param name="h2">
                                <meta>
                                    <title lang="en">H2</title>
                                    <title lang="de">H2</title>
                                </meta>

                            </param>
                            <param name="h3">
                                <meta>
                                    <title lang="en">H3</title>
                                    <title lang="de">H3</title>
                                </meta>

                            </param>
                            <param name="p">
                                <meta>
                                    <title lang="en">P</title>
                                    <title lang="de">P</title>
                                </meta>
                            </param>
                        </param>
                    </params>
                </property>
                <xi:include href="../_fragments/attr_class.xml" xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)
                      xpointer(/sulu:properties/*)"/>

            </properties>
        </section>
        <section name="config_2">
            <meta>
                <title lang="en">Settings for the icon</title>
                <title lang="de">Einstellungen für das Icon</title>
            </meta>

            <properties>
                <property name="loading" type="single_select">
                    <meta>
                        <title lang="en">Loading images</title>
                        <title lang="de">Laden von Bildern</title>
                    </meta>

                    <params>
                        <param name="default_value" value="lazy"/>

                        <param name="values" type="collection">
                            <param name="lazy">
                                <meta>
                                    <title lang="en">lazy</title>
                                    <title lang="de">auf dem letzten Drücker</title>
                                </meta>
                            </param>

                            <param name="eager">
                                <meta>
                                    <title lang="en">eager</title>
                                    <title lang="de">bevorzugt</title>
                                </meta>
                            </param>
                        </param>
                    </params>
                </property>
                <property name="fetchpriority_high" type="checkbox">
                    <meta>
                        <title lang="en">Fetch priority high</title>
                        <title lang="de">Hohe Ladepriorität</title>
                        <info_text lang="en">Activate this option if the image is the first one on the page. The image
                            will then be assigned the attribute 'fetchpriority="high"', telling the browser to load it
                            with higher priority. This can help improve the Largest Contentful Paint (LCP).
                        </info_text>
                        <info_text lang="de">Setze diese Option, wenn das Bild das erste Bild auf der Seite ist. Diesem
                            Bild wird dann das Attribut 'fetchpriority="high"' hinzugefügt, was dem Browser mitteilt,
                            dass das Bild mit höherer Priorität geladen werden soll, was den Largest Contentful Paint
                            (LCP) verbessern kann.
                        </info_text>

                    </meta>
                    <params>
                        <param name="type" value="toggler"/>
                        <param name="default_value" value="false"/>
                    </params>
                </property>
                <property name="is_decorative" type="checkbox">
                    <meta>
                        <title lang="en">Mark images as decorative</title>
                        <title lang="de">Bilder als ausschließlich dekorativ kennzeichen</title>
                        <info_text lang="en">When this option is enabled, the image information will not be read out by
                            screen readers. This means that the "alt" and "title" tags will remain empty.
                        </info_text>
                        <info_text lang="de">Wenn diese Option eingeschaltet ist, werden die Bildinformationen nicht von
                            Screenreadern vorgelesen, das heißt, der "alt"-Tag und "title"-Tag bleiben leer.
                        </info_text>
                    </meta>
                    <params>
                        <param name="type" value="toggler"/>
                        <param name="default_value" value="false"/>
                    </params>
                </property>

            </properties>
        </section>
        <section name="accessibility">
            <meta>
                <title lang="en">Accessibility</title>
                <title lang="de">Barrierefreiheit</title>
            </meta>

            <properties>
                <block name="aria_blocks" default-type="aria-attr--aria-label" minOccurs="0">

                    <params>
                        <param name="add_button_text">
                            <meta>
                                <title lang="en">Add ARIA Values</title>
                                <title lang="de">ARIA-Werte hinzufügen</title>
                            </meta>
                        </param>
                        <param name="block_id_generator" value="true"/>
                    </params>
                    <types>
                        <type ref="aria-block--heading"/>
                        <type ref="aria-attr--aria-label"/>
                    </types>
                </block>

            </properties>
        </section>
    </properties>
</template>
